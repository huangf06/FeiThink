---
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'

const { currentLang, isHome, isPost, isEssays, isWork, isAbout, getLocalizedPath } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

const isHomeActive = isHome
const isEssaysActive = isEssays || isPost
const isWorkActive = isWork
const isAboutActive = isAbout

function getNavItemClass(isActive: boolean) {
  return isActive
    ? 'highlight-static c-primary font-bold after:bottom-0.7em'
    : 'highlight-hover transition-[colors,font-weight] after:bottom-0.7em hover:(c-primary font-bold)'
}

const navItems = [
  {
    href: getLocalizedPath('/'),
    label: currentUI.home,
    className: getNavItemClass(isHomeActive),
  },
  {
    href: '/essays/',
    label: currentUI.essays,
    className: getNavItemClass(isEssaysActive),
  },
  {
    href: '/work/',
    label: currentUI.work,
    className: getNavItemClass(isWorkActive),
  },
  {
    href: getLocalizedPath('/about/'),
    label: currentUI.about,
    className: getNavItemClass(isAboutActive),
  },
]
---

<nav
  aria-label="Site Navigation"
  class:list={[
    'mb-10.5 text-3.6 font-semibold leading-2.45em font-navbar',
    'lg:(uno-desktop-column text-4 bottom-[min(9.04rem+3.85vw,12.5rem)]) cjk:tracking-wide',
    isPost ? 'hidden lg:block' : '',
  ]}
>
  <ul>
    {navItems.map(item => (
      <li>
        <a
          href={item.href}
          class={item.className}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
