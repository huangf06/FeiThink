---
import Layout from '@/layouts/Layout.astro'
---

<Layout postTitle="Work" postDescription="Academic work, projects, credentials.">
  <article class="heti">
    <header class="mb-8">
      <h1 class="mb-2 text-5.5 font-bold leading-tight cjk:tracking-wide lg:text-6">
        Work
      </h1>
      <p class="text-3.8 leading-1.6 c-secondary lg:text-4">
        Data &amp; AI engineering. Ten years in quantitative research and
        machine learning.
      </p>
    </header>

    <section class="mb-8">
      <h2>Academic</h2>
      <p>
        <strong>M.Sc. Artificial Intelligence</strong>, Vrije Universiteit
        Amsterdam (2023 – 2025). GPA 8.2 / 10.
      </p>
      <p>
        <strong>B.Eng. Industrial Engineering</strong>, Tsinghua University
        (2006 – 2010).
      </p>
    </section>

    <section class="mb-8">
      <h2>Credentials</h2>
      <ul>
        <li>Databricks Certified Data Engineer Professional.</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2>Experience</h2>
      <p>
        Henan Energy Group (Business Analyst) → Ele.me (Data Analyst) → BQ
        Investment (Quantitative Researcher) → GLP Technology (Lead Data
        Engineer) → Independent Quantitative Researcher → VU Amsterdam (M.Sc.
        AI). Full timeline on
        <a
          class="highlight-hover transition-colors hover:c-primary"
          href="https://www.linkedin.com/in/huangf06/"
          target="_blank"
          rel="noopener noreferrer"
        >LinkedIn</a>.
      </p>
    </section>

    <section>
      <h2>Projects</h2>
      <p>
        Selected public work on
        <a
          class="highlight-hover transition-colors hover:c-primary"
          href="https://github.com/huangf06"
          target="_blank"
          rel="noopener noreferrer"
        >GitHub</a>.
      </p>
    </section>
  </article>
</Layout>
